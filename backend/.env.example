# ---- AI provider selection ----
# Which AI provider to use for CSV field extraction: gemini | groq | ollama
AI_PROVIDER=gemini

# ---- Gemini (Google) — cloud, free tier ----
# Free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ---- Groq (fast cloud-hosted Llama) — cloud, free tier ----
# Free key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Ollama (local, self-hosted Llama) — free, no key, runs on your machine ----
# Install: https://ollama.com, then run: ollama pull llama3.1
# If AI_PROVIDER=ollama and you're using Docker Compose, leave this as
# http://host.docker.internal:11434 so the backend container can reach the
# Ollama server running on your host machine.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Port the backend server listens on
PORT=4000

# Comma-separated list of allowed origins for CORS (your deployed frontend URL)
CORS_ORIGIN=http://localhost:3000

# How many CSV rows to send to the AI per batch
BATCH_SIZE=25

# How many times to retry a failed AI batch before giving up
MAX_RETRIES=3
